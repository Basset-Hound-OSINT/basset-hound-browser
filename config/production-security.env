# Basset Hound Browser - Production Security Configuration
# Version: v12.7.0+
# Purpose: WSS/HTTPS enforcement and IP redaction for production deployment

# ==================================================
# WebSocket Secure (WSS) Configuration
# ==================================================

# Enable WSS enforcement in production (REQUIRED)
# This forces all WebSocket connections to use secure protocol
BASSET_WS_ENFORCE_WSS=true

# HTTPS redirect enforcement
# Automatically redirects HTTP requests to HTTPS
BASSET_WS_ENFORCE_HTTPS_REDIRECT=true

# SSL Certificate paths (REQUIRED for WSS)
# Generate certificates:
#   openssl genrsa -out server-key.pem 2048
#   openssl req -new -x509 -key server-key.pem -out server-cert.pem -days 365
BASSET_WS_SSL_CERT=/etc/basset-hound/certs/server-cert.pem
BASSET_WS_SSL_KEY=/etc/basset-hound/certs/server-key.pem

# Optional: CA certificate for client certificate verification
# Enable for mutual TLS (mTLS) authentication
# BASSET_WS_SSL_CA=/etc/basset-hound/certs/ca-cert.pem

# Minimum TLS version (TLSv1.2 or TLSv1.3)
# TLSv1.2 for compatibility, TLSv1.3 for maximum security
BASSET_WS_MIN_TLS_VERSION=TLSv1.2

# WebSocket ports
WS_PORT=8765              # HTTPS/WSS port (primary)
WS_HTTP_REDIRECT_PORT=8080  # HTTP redirect port (optional)

# ==================================================
# IP Redaction Configuration
# ==================================================

# Enable IP redaction from device fingerprints
# Prevents WebRTC IP leaks in exported device IDs
BASSET_IP_REDACTION_ENABLED=true

# IP privacy mode: 'mask', 'remove', or 'obfuscate'
# - mask: Preserve format but change actual address (default)
# - remove: Completely remove IP addresses
# - obfuscate: Fully randomize all octets
BASSET_IP_PRIVACY_MODE=mask

# Enable consistent IP masking within session
# Same IP always gets same mask during session (prevents fingerprinting)
BASSET_IP_CONSISTENT_MASKING=true

# Preserve network topology information in masked IPs
# Keep first octet for private ranges to indicate local vs public
BASSET_IP_PRESERVE_NETWORK_INFO=true

# ==================================================
# Security Hardening
# ==================================================

# Require valid SSL certificate (no self-signed in production)
BASSET_WS_REQUIRE_VALID_CERTIFICATE=true

# Reject unauthorized certificate connections
BASSET_WS_REJECT_UNAUTHORIZED=true

# Additional security headers
BASSET_SECURITY_HEADERS=true
BASSET_HSTS_MAX_AGE=31536000
BASSET_X_FRAME_OPTIONS=DENY
BASSET_X_CONTENT_TYPE_OPTIONS=nosniff

# ==================================================
# Authentication
# ==================================================

# Require authentication token for WebSocket connections
# Generate: openssl rand -base64 32
BASSET_WS_AUTH_ENABLED=true
BASSET_WS_TOKEN=<your-secure-token-here>

# ==================================================
# Monitoring and Logging
# ==================================================

# Log level for security-related events
LOG_LEVEL=info

# Enable detailed SSL/TLS logging
BASSET_WS_DEBUG_SSL=false

# Enable IP redaction detailed logging
BASSET_IP_REDACTION_DEBUG=false

# Health check endpoint (doesn't require authentication)
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_ENABLED=true

# ==================================================
# Compliance
# ==================================================

# Data retention policy
# How long to keep IP mapping data
BASSET_IP_MAPPING_RETENTION_HOURS=24

# GDPR compliance mode
# Automatically redacts sensitive data in logs
BASSET_GDPR_MODE=true

# ==================================================
# Feature Flags
# ==================================================

# Allow mixed mode (HTTP + HTTPS) - ONLY for testing
# Must be false in production
BASSET_ALLOW_MIXED_MODE=false

# Allow non-secure WebSocket fallback
# Must be false in production
BASSET_ALLOW_WS_FALLBACK=false

# ==================================================
# Deployment Environment
# ==================================================

# Environment indicator
NODE_ENV=production

# Application version
VERSION=12.7.0

# Deployment identifier (for tracking)
DEPLOYMENT_ID=production-v12.7.0-security
