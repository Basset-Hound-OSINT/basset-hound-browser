# Basset Hound Browser - Development Environment Configuration
# Version: v12.3.0+ (Continuous, Weekly Auto-Deploys)
# Purpose: Testing ground for v12.4.0+ with experimental features

# Application Environment
NODE_ENV=development
LOG_LEVEL=debug
DEBUG=basset:*

# Version (Always Latest)
VERSION=12.3.0
IMAGE_TAG=latest

# WebSocket Server Configuration
WS_PORT=8766
WS_HOST=0.0.0.0
WS_SECURE=false

# Display and UI Configuration
DISPLAY=:99
SCREEN_RESOLUTION=1920x1080x24

# Electron Configuration
ELECTRON_DISABLE_SANDBOX=1
ELECTRON_DEBUG=false

# Tor Configuration (System Tor)
USE_SYSTEM_TOR=true
TOR_SOCKS_PORT=9050
TOR_CONTROL_PORT=9051

# Database Configuration
DATABASE_URL=file:/app/data/basset-dev.db
DATABASE_SCHEMA=v12.3.0-dev

# Logging Configuration
LOG_DIR=/app/logs
LOG_FILE_MAX_SIZE=50m
LOG_FILE_MAX_FILES=5

# Performance Configuration
COMPRESSION_LEVEL=6
MEMORY_LIMIT_MB=3800
CPU_LIMIT=4

# Health Check Configuration
HEALTH_CHECK_INTERVAL=15s
HEALTH_CHECK_TIMEOUT=5s
HEALTH_CHECK_RETRIES=2

# Monitoring Configuration
PROMETHEUS_ENABLED=true
METRICS_PORT=9091
METRICS_PATH=/metrics

# Security Configuration
SECURITY_MODE=development
NO_NEW_PRIVILEGES=true
DROP_CAPABILITIES=true

# Feature Flags (Development - All Enabled)
FEATURE_EXPERIMENTAL=true
FEATURE_DEBUG_MODE=true
FEATURE_HOT_RELOAD=true

# Update Configuration
AUTO_UPDATE_ENABLED=false
UPDATE_CHECK_INTERVAL=3600

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_INTERVAL=3600
BACKUP_RETENTION_DAYS=7

# Development Auto-Deploy
AUTO_DEPLOY_ENABLED=true
AUTO_DEPLOY_BRANCH=main
AUTO_DEPLOY_INTERVAL=3600

# Testing Configuration
TEST_MODE=true
TEST_TIMEOUT=30s
VERBOSE_OUTPUT=true
