# Basset Hound Browser - Production Environment Configuration
# Version: v12.2.0 (Stable, Quarterly Updates)
# Purpose: Production deployment with strict SLA (99.9% uptime)

# Application Environment
NODE_ENV=production
LOG_LEVEL=info

# Version Lock (Do NOT change without approval)
VERSION=12.2.0
IMAGE_TAG=v12.2.0

# WebSocket Server Configuration
WS_PORT=8765
WS_HOST=0.0.0.0
WS_SECURE=false

# Display and UI Configuration
DISPLAY=:99
SCREEN_RESOLUTION=1920x1080x24

# Electron Configuration
ELECTRON_DISABLE_SANDBOX=1
ELECTRON_DEBUG=false

# Tor Configuration (System Tor)
USE_SYSTEM_TOR=true
TOR_SOCKS_PORT=9050
TOR_CONTROL_PORT=9051

# Database Configuration
DATABASE_URL=file:/app/data/basset.db
DATABASE_SCHEMA=v12.2.0

# Logging Configuration
LOG_DIR=/app/logs
LOG_FILE_MAX_SIZE=10m
LOG_FILE_MAX_FILES=5

# Performance Configuration
COMPRESSION_LEVEL=6
MEMORY_LIMIT_MB=1900
CPU_LIMIT=2

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_RETRIES=3

# Monitoring Configuration
PROMETHEUS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics

# Security Configuration
SECURITY_MODE=strict
NO_NEW_PRIVILEGES=true
DROP_CAPABILITIES=true

# Feature Flags (Production - Conservative)
FEATURE_EXPERIMENTAL=false
FEATURE_DEBUG_MODE=false
FEATURE_HOT_RELOAD=false

# Update Configuration
AUTO_UPDATE_ENABLED=false
UPDATE_CHECK_INTERVAL=604800

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400
BACKUP_RETENTION_DAYS=30

# Rollback Configuration
ROLLBACK_ENABLED=true
ROLLBACK_VERSION=12.1.0
