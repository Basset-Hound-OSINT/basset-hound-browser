{
  "name": "basset-hound-mobile",
  "version": "1.0.0",
  "description": "Mobile dashboard for Basset Hound Browser competitor monitoring (iOS/Android)",
  "main": "index.js",
  "scripts": {
    "start": "react-native start",
    "start:ios": "react-native run-ios",
    "start:android": "react-native run-android",
    "build:ios": "cd ios && xcodebuild -workspace BassetHoundMobile.xcworkspace -scheme BassetHoundMobile -configuration Release",
    "build:android": "cd android && ./gradlew assembleRelease",
    "android:dev": "react-native run-android --variant=debug",
    "android:build": "cd android && ./gradlew assembleRelease && ./gradlew bundleRelease",
    "ios:dev": "react-native run-ios",
    "ios:build": "cd ios && xcodebuild -workspace BassetHoundMobile.xcworkspace -scheme BassetHoundMobile -configuration Release -archivePath ./build/BassetHound.xcarchive archive",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-native": "0.74.1",
    "@react-native-community/netinfo": "^11.3.1",
    "@react-native-async-storage/async-storage": "^1.23.1",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/stack": "^6.3.29",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "react-native-screens": "^3.29.0",
    "react-native-safe-area-context": "^4.10.5",
    "react-native-gesture-handler": "^2.14.5",
    "react-native-vector-icons": "^10.1.0",
    "zustand": "^4.5.2",
    "axios": "^1.7.2",
    "date-fns": "^3.6.0",
    "react-native-svg": "^15.1.0",
    "react-native-svg-charts": "^5.8.0",
    "react-native-push-notification": "^8.1.1",
    "@react-native-firebase/app": "^18.8.0",
    "@react-native-firebase/messaging": "^18.8.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.4",
    "@babel/preset-env": "^7.24.4",
    "@babel/preset-typescript": "^7.24.1",
    "@types/react": "^18.3.1",
    "@types/react-native": "^0.74.1",
    "@typescript-eslint/eslint-plugin": "^7.5.0",
    "@typescript-eslint/parser": "^7.5.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "typescript": "^5.4.5",
    "eslint": "^9.1.1",
    "eslint-config-react-app": "^7.0.1",
    "prettier": "^3.2.5",
    "@testing-library/react-native": "^12.5.0",
    "@testing-library/jest-native": "^5.4.3"
  },
  "jest": {
    "preset": "react-native",
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/**/*.test.tsx"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5",
    "bracketSpacing": true,
    "tabWidth": 2
  }
}
