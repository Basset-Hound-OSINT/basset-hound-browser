# Basset Hound Browser - Production Environment Variables
# Copy this file to .env.prod and customize as needed
# SECURITY: Review all settings before deploying to production

# ============================================================================
# Environment
# ============================================================================
NODE_ENV=production
LOG_LEVEL=error

# ============================================================================
# Logging & Debugging
# ============================================================================
# Minimal debug output (errors only)
DEBUG=

# Disable Electron logging to reduce I/O
ELECTRON_ENABLE_LOGGING=false

# Disable verbose WebSocket logging
VERBOSE_WS=false

# ============================================================================
# Display & UI
# ============================================================================
# Xvfb display number (for headless rendering)
DISPLAY=:99

# ============================================================================
# Features
# ============================================================================
# Disable hot reload in production
HOT_RELOAD=false

# Disable dev tools in Electron
ELECTRON_ENABLE_DEV_TOOLS=false

# Disable experimental features
EXPERIMENTAL=false

# ============================================================================
# Network
# ============================================================================
# WebSocket server port
WEBSOCKET_PORT=8765

# WebSocket server host (localhost only - use reverse proxy for external access)
WEBSOCKET_HOST=127.0.0.1

# Disable request logging (use centralized logging instead)
LOG_REQUESTS=false

# ============================================================================
# Tor Configuration
# ============================================================================
# Use system Tor service
USE_SYSTEM_TOR=true

# Tor SOCKS port
TOR_SOCKS_PORT=9050

# Tor control port
TOR_CONTROL_PORT=9051

# ============================================================================
# Security (Production - strict)
# ============================================================================
# Rate limiting enabled and enforced
RATE_LIMIT=true

# Rate limit requests per second (conservative for production)
RATE_LIMIT_RPS=100

# Reject self-signed certificates
ALLOW_SELF_SIGNED=false

# Require TLS 1.2 or higher
MIN_TLS_VERSION=1.2

# Security strict mode (enforces all security controls)
SECURITY_STRICT=true

# ============================================================================
# Performance
# ============================================================================
# Node.js max old space size (MB) - increased for production
NODE_OPTIONS=--max-old-space-size=2048

# Maximum concurrent connections (conservative)
MAX_CONNECTIONS=50

# Request timeout (ms)
REQUEST_TIMEOUT=30000

# Enable compression for responses
COMPRESSION_ENABLED=true

# Compression level (1-9, higher = more CPU, better compression)
COMPRESSION_LEVEL=6

# ============================================================================
# Storage
# ============================================================================
# Data directory for profiles, cache, etc. (should be a volume mount)
DATA_DIR=/app/data

# Downloads directory (should be a volume mount)
DOWNLOADS_DIR=/app/downloads

# Screenshots directory (should be a volume mount)
SCREENSHOTS_DIR=/app/screenshots

# Logs directory (should be a volume mount for centralized logging)
LOGS_DIR=/app/logs

# ============================================================================
# Monitoring & Alerting
# ============================================================================
# Enable health check endpoint
HEALTH_CHECK_ENABLED=true

# Health check interval (seconds)
HEALTH_CHECK_INTERVAL=30

# Send metrics to monitoring service
METRICS_ENABLED=false

# Metrics service URL (optional)
# METRICS_URL=https://monitoring.example.com

# ============================================================================
# Production-specific Options
# ============================================================================
# Enable request validation (strict schema validation)
STRICT_VALIDATION=true

# Enable audit logging (all API calls logged)
AUDIT_LOGGING=true

# Audit log file (should be mounted volume)
AUDIT_LOG_FILE=/app/logs/audit.log

# Enable CORS restrictions
CORS_ENABLED=true

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:8765,http://127.0.0.1:8765

# Request signature validation
SIGNATURE_VALIDATION=false

# API key validation (if implemented)
API_KEY_REQUIRED=false

# ============================================================================
# Database/Cache (if applicable)
# ============================================================================
# Redis connection (optional, for distributed caching)
# REDIS_URL=redis://localhost:6379

# Database URL (if applicable)
# DATABASE_URL=postgresql://user:pass@localhost:5432/basset

# ============================================================================
# SSL/TLS Certificate (for WSS support)
# ============================================================================
# Enable WebSocket Secure (WSS) - RECOMMENDED for production
# Default: true (automatically enabled in production)
BASSET_WS_SSL_ENABLED=true

# Path to TLS certificate file (PEM format, mounted as volume)
# Should be Let's Encrypt fullchain.pem or equivalent
# Example: /etc/letsencrypt/live/yourdomain.com/fullchain.pem
BASSET_WS_SSL_CERT=/etc/basset/certs/cert.pem

# Path to TLS private key file (PEM format, mounted as volume)
# Should be Let's Encrypt privkey.pem or equivalent
# Permissions: 600 (read-only for security)
BASSET_WS_SSL_KEY=/etc/basset/certs/key.pem

# Optional: CA certificate for client verification (mutual TLS)
# Only needed if you require client certificates to connect
# BASSET_WS_SSL_CA=/etc/basset/certs/ca.pem

# ============================================================================
# Deployment-specific
# ============================================================================
# Cluster mode (for multi-instance deployments)
CLUSTER_MODE=false

# Cluster ID (if using multiple instances)
# CLUSTER_ID=1

# Service discovery URL (if using container orchestration)
# SERVICE_DISCOVERY_URL=http://consul:8500

# Environment/Region identifier
ENVIRONMENT=production
REGION=us-east-1
