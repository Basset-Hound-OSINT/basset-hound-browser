{
  "extends": ["eslint:recommended"],
  "env": {
    "browser": true,
    "es2021": true
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    "no-case-declarations": "warn"
  },
  "overrides": [
    {
      "files": ["src/**/__tests__/**/*"],
      "rules": {
        "no-console": "off"
      }
    }
  ]
}
