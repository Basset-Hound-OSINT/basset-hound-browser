{
  "name": "basset-hound-dashboard-web",
  "version": "1.0.0",
  "description": "Enterprise web dashboard for Basset Hound Browser competitor monitoring",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "vite --port 3000",
    "build": "vite build",
    "preview": "vite preview --port 3000",
    "test": "jest",
    "test:unit": "jest --testMatch='**/__tests__/unit/**/*.test.js'",
    "test:integration": "jest --testMatch='**/__tests__/integration/**/*.test.js' --testTimeout=10000",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --coverageDirectory=coverage",
    "lint": "eslint src --ext .js,.jsx --fix",
    "type-check": "tsc --noEmit",
    "analyze": "vite-bundle-visualizer"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "axios": "^1.7.2",
    "chart.js": "^4.4.2",
    "react-chartjs-2": "^5.2.0",
    "date-fns": "^3.6.0",
    "zustand": "^4.5.2",
    "react-router-dom": "^6.23.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.1.4",
    "vite-bundle-visualizer": "^1.2.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "@testing-library/react": "^15.0.6",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/user-event": "^14.5.2",
    "babel-jest": "^29.7.0",
    "@babel/preset-env": "^7.24.4",
    "@babel/preset-react": "^7.24.1",
    "css-loader": "^6.10.0",
    "style-loader": "^3.3.4",
    "prettier": "^3.2.5",
    "eslint": "^9.1.1",
    "eslint-config-react-app": "^7.0.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
