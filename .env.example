# Basset Hound Browser - Environment Configuration
# Copy this file to .env and customize for your deployment
# Usage: docker-compose --env-file .env up -d

# ============================================================================
# RUNTIME CONFIGURATION
# ============================================================================

# Environment (development, staging, production)
ENVIRONMENT=production

# Node.js environment
NODE_ENV=production

# Log level (error, warn, info, debug, trace)
LOG_LEVEL=info

# ============================================================================
# NETWORK & PORTS
# ============================================================================

# WebSocket server port
WS_PORT=8765

# ============================================================================
# DISPLAY & RENDERING
# ============================================================================

# Virtual display resolution (WIDTHxHEIGHTxDEPTH)
SCREEN_RESOLUTION=1920x1080x24

# Headless mode (true/false) - set to false for development
HEADLESS_MODE=true

# ============================================================================
# TOR & PROXY CONFIGURATION
# ============================================================================

# Enable Tor (true/false)
USE_SYSTEM_TOR=true

# Tor SOCKS port
TOR_SOCKS_PORT=9050

# Tor control port
TOR_CONTROL_PORT=9051

# Optional: Proxy URL (http://host:port or socks5://host:port)
# PROXY_URL=http://proxy.example.com:8080

# ============================================================================
# CONTAINER RESOURCE LIMITS
# ============================================================================

# CPU allocation
# Examples: "2.0" = 2 cores, "0.5" = 0.5 cores
CONTAINER_CPU_LIMIT=2.0
CONTAINER_CPU_RESERVED=0.5

# Memory allocation
# Examples: "2G" = 2GB, "512M" = 512MB
CONTAINER_MEMORY_LIMIT=2G
CONTAINER_MEMORY_RESERVED=512M

# Node.js max memory (MB)
# Should be less than CONTAINER_MEMORY_LIMIT
NODE_MAX_MEMORY=2048

# ============================================================================
# DATA PERSISTENCE
# ============================================================================

# Enable data persistence (true/false)
PERSIST_DATA=true

# Data retention (days) - 0 = unlimited
DATA_RETENTION_DAYS=30

# Auto-cleanup old logs
AUTO_CLEANUP_LOGS=true

# ============================================================================
# SECURITY & AUTHENTICATION
# ============================================================================

# WebSocket authentication token (optional)
# Leave empty to disable token authentication
# BASSET_WS_TOKEN=your-secret-token-here

# Enable SSL/TLS for WebSocket (wss://)
# Default: true in production, false in development
# BASSET_WS_SSL_ENABLED=false

# SSL certificate path (PEM format)
# Required if BASSET_WS_SSL_ENABLED=true
# Example paths:
#   /etc/letsencrypt/live/yourdomain.com/fullchain.pem
#   /run/secrets/server_cert (Docker Secrets)
#   ./certs/cert.pem (Local file)
# BASSET_WS_SSL_CERT=/etc/basset/certs/cert.pem

# SSL private key path (PEM format)
# Required if BASSET_WS_SSL_ENABLED=true
# BASSET_WS_SSL_KEY=/etc/basset/certs/key.pem

# Optional: CA certificate for client verification (mutual TLS)
# Only needed if you require client certificates
# BASSET_WS_SSL_CA=/etc/basset/certs/ca.pem

# ============================================================================
# FINGERPRINTING & EVASION
# ============================================================================

# Fingerprint profile (random, chrome, firefox, safari, edge, mobile)
FINGERPRINT_PROFILE=random

# User-Agent category (desktop, mobile, tablet, bot-like)
USER_AGENT_CATEGORY=desktop

# Enable behavioral AI evasion
ENABLE_BEHAVIORAL_AI=true

# Enable canvas fingerprinting evasion
ENABLE_CANVAS_EVASION=true

# Enable WebGL fingerprinting evasion
ENABLE_WEBGL_EVASION=true

# ============================================================================
# LOGGING & MONITORING
# ============================================================================

# Enable detailed metrics logging
METRICS_ENABLED=true

# Enable performance profiling
PROFILING_ENABLED=false

# Maximum log file size (10m = 10MB)
LOG_MAX_SIZE=10m

# Number of log file rotations to keep
LOG_MAX_FILES=10

# ============================================================================
# DEVELOPMENT / DEBUG
# ============================================================================

# Debug mode (enables verbose logging)
DEBUG=false

# Enable test mode
TEST_MODE=false

# Enable profiling
ENABLE_PROFILING=false

# ============================================================================
# DOCKER COMPOSE DEFAULTS
# ============================================================================

# Container restart behavior
# on-failure (default), always, no, unless-stopped
RESTART_POLICY=on-failure:5

# Compose project name
COMPOSE_PROJECT_NAME=basset-hound-browser
