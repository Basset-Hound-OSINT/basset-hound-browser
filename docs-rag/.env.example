# ──────────────────────────────────────────────
# RAG Bootstrap – CONSUMER Environment (image mode)
# ──────────────────────────────────────────────
# SNAPSHOT of the live deployment's .env with the ONE secret redacted
# (POSTGRES_PASSWORD). The real .env lives ONLY in the deployment dir
# (/mnt/quickiespace/rag-instances/basset-hound-docs-rag/.env, mode 600) and is
# never committed. To rebuild: copy this to that dir as `.env`, set a real
# POSTGRES_PASSWORD, then `./rag up`. See README.md in this folder.
#
# This consumer runs PRE-BUILT images (no application source). Build them once
# on this host with the canonical repo's `rag build`, then pin the
# tag via RAG_IMAGE_TAG below.
#
# HARD PREREQUISITE: a reachable Ollama with the embedding model pulled
# (`ollama pull nomic-embed-text`). `rag doctor` preflights it.
# ──────────────────────────────────────────────

# ── Instance identity ─────────────────────────────────────────────────────────
PROJECT_NAME=basset-hound-docs-rag
COMPOSE_PROJECT_NAME=basset-hound-docs-rag
RAG_NETWORK_NAME=basset-hound-docs-rag-net

# ── Image pin (LOCAL Docker daemon; no registry) ──────────────────────────────
RAG_IMAGE_TAG=0.4.2

# ── Port scheme — RAG_PORT_BASE derives all published host ports ───────────────
# 20-wide band [BASE .. BASE+19]; base is a multiple of 20 and >= 10020.
RAG_PORT_BASE=10080
RAG_PORT=10080

# ── Data location (DIRECT-PATH: EVERY volume under RAG_DATA_ROOT) ──────────────
# Every data volume (postgres/redis included) binds directly under this root, on
# the quickiespace drive — nothing large lands on the home/root partition.
RAG_DATA_ROOT=/mnt/quickiespace/rag-instances/basset-hound-docs-rag/data
RAG_POSTGRES_VOLUME=/mnt/quickiespace/rag-instances/basset-hound-docs-rag/data/postgres
RAG_REDIS_VOLUME=/mnt/quickiespace/rag-instances/basset-hound-docs-rag/data/redis
RAG_DOCS_VOLUME=/mnt/quickiespace/rag-instances/basset-hound-docs-rag/data/docs
RAG_CACHE_VOLUME=/mnt/quickiespace/rag-instances/basset-hound-docs-rag/data/cache
RAG_LOGS_VOLUME=/mnt/quickiespace/rag-instances/basset-hound-docs-rag/data/logs

# DOCS_PATH: same-path read-only mount so stored citation filepaths are
# host-openable. This is the corpus the RAG indexes.
DOCS_PATH=/home/devel/basset-hound-browser/docs
RAG_INGEST_ROOT_GUARD=on

# ── PostgreSQL (internal Docker network only; never published) ────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ragdb
POSTGRES_USER=raguser
# REDACTED — the real value lives only in the deployment's .env (mode 600).
# Generate a fresh random secret on rebuild, e.g. `openssl rand -hex 24`.
POSTGRES_PASSWORD=CHANGEME_generate_a_random_secret

# ── Redis (internal Docker network only) ──────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Embeddings — canonical triple (change all three together + reindex) ───────
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768
EMBEDDING_BACKEND=ollama

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=256
CHUNK_OVERLAP=50

# ── Ollama (serves embeddings + LLM generation; EXTERNAL host/remote) ─────────
# host.docker.internal resolves to the host via compose extra_hosts host-gateway.
# NOTE: host Ollama binds 127.0.0.1 — the rootless forwarder
# `ollama-rag-bridge.service` (bind 172.17.0.1) bridges the docker gateway to it.
OLLAMA_BASE_URL=http://host.docker.internal:11434
LLM_MODEL=llama3.2:3b
LLM_TEMPERATURE=0.3
LLM_TIMEOUT=300

# ── Retrieval ─────────────────────────────────────────────────────────────────
RAG_TOP_K=5
RAG_MIN_SIMILARITY=0.7
RAG_HNSW_EF_SEARCH=100

# ── Auto-ingest watcher — OFF by default (fleet inotify safety) ───────────────
# WATCHER_ENABLED=false
# WATCHER_ARCHIVE_MODE=off

# ── Memory caps — per-service hard limits (fleet-resource hardening) ──────────
# RAG_API_MEM_LIMIT=512m
# RAG_PG_MEM_LIMIT=1g
# RAG_REDIS_MEM_LIMIT=256m
# RAG_FRONTEND_MEM_LIMIT=128m
# RAG_REDIS_MAXMEMORY=192mb

# ── Monitoring ports (derived; stack works without them) ──────────────────────
RAG_PROMETHEUS_PORT=10090
RAG_GRAFANA_PORT=10091
RAG_LOKI_PORT=10092
RAG_ALERTMANAGER_PORT=10093
RAG_PG_EXPORTER_PORT=10094
RAG_REDIS_EXPORTER_PORT=10095
RAG_CADVISOR_PORT=10096
