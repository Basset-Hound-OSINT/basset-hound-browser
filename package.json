{
  "name": "basset-hound-browser",
  "version": "12.8.0",
  "description": "Browser automation tool with anti-detection evasion and forensic data collection",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "start:dev": "cross-env NODE_ENV=development electron . --dev",
    "start:prod": "cross-env NODE_ENV=production electron .",
    "start:headless": "env -u ELECTRON_RUN_AS_NODE -u ELECTRON_NO_ATTACH_CONSOLE cross-env NODE_ENV=production ELECTRON_DISABLE_SANDBOX=1 electron . --headless --no-sandbox --disable-gpu --disable-dev-shm-usage",
    "start:gui": "electron . --gui",
    "dev": "electron . --dev",
    "smoke:mvp": "node scripts/smoke-mvp.js",
    "build": "electron-builder",
    "build:dev": "cross-env NODE_ENV=development electron-builder",
    "build:prod": "cross-env NODE_ENV=production electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "pack": "electron-builder --dir",
    "test:cleanup": "node scripts/clean-test-artifacts.js",
    "test": "npm run test:cleanup && npm run test:unit && npm run test:integration",
    "test:all": "npm run test:cleanup && npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:unit": "node --expose-gc ./node_modules/.bin/jest tests/unit --coverage --maxWorkers=2 --testTimeout=30000",
    "test:integration": "node --expose-gc ./node_modules/.bin/jest tests/integration --maxWorkers=1 --testTimeout=60000",
    "test:e2e": "node --expose-gc ./node_modules/.bin/jest tests/e2e --maxWorkers=1 --testTimeout=180000",
    "test:stress": "node --expose-gc ./node_modules/.bin/jest tests/stress --maxWorkers=1 --testTimeout=120000",
    "test:bot-detection": "node --expose-gc ./node_modules/.bin/jest tests/bot-detection --maxWorkers=1 --testTimeout=120000",
    "test:legacy": "node tests/integration.test.js",
    "test:verbose": "jest --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --coverageDirectory=coverage",
    "test:ci": "jest --ci --coverage --reporters=default --reporters=jest-junit",
    "test:evasion": "node tests/integration.test.js --evasion",
    "test:client": "node tests/test-client.js --interactive",
    "test:client:run": "node tests/test-client.js --test",
    "test:pre-deployment": "mocha tests/pre-deployment-validation.test.js --timeout 300000 --exit --reporter spec",
    "test:pre-deployment:verbose": "mocha tests/pre-deployment-validation.test.js --timeout 300000 --exit --reporter spec --grep .",
    "test:integration:all": "node tests/integration/run-all.js",
    "test:integration:communication": "node tests/integration/extension-browser/communication.test.js",
    "test:integration:command-sync": "node tests/integration/extension-browser/command-sync.test.js",
    "test:integration:session-sharing": "node tests/integration/extension-browser/session-sharing.test.js",
    "test:integration:form-filling": "node tests/integration/scenarios/form-filling.test.js",
    "test:integration:navigation": "node tests/integration/scenarios/navigation.test.js",
    "test:integration:data-extraction": "node tests/integration/scenarios/data-extraction.test.js",
    "test:integration:screenshot": "node tests/integration/scenarios/screenshot.test.js",
    "test:integration:protocol": "node tests/integration/protocol.test.js",
    "test:integration:scenarios": "node tests/integration/scenarios/form-filling.test.js && node tests/integration/scenarios/navigation.test.js && node tests/integration/scenarios/data-extraction.test.js && node tests/integration/scenarios/screenshot.test.js",
    "test:v12.9.0": "node tests/v12-9-0/test-runner.js all",
    "test:v12.9.0:compression": "node tests/v12-9-0/test-runner.js compression",
    "test:v12.9.0:forensics": "node tests/v12-9-0/test-runner.js forensics",
    "test:v12.9.0:watch": "nodemon --exec 'npm run test:v12.9.0' --watch tests/v12-9-0",
    "test:v12.9.0:verbose": "node tests/v12-9-0/test-runner.js all --verbose",
    "test:v12.9.0:report": "npm run test:v12.9.0 -- --reporter=json --outputFile=test-report-v12.9.0.json",
    "test:v12.9.0:performance": "node tests/v12-9-0/test-runner.js all --reporter=json",
    "test:v12.9.0:performance:compare": "node scripts/compare-performance.js v12.9.0",
    "test:v12.9.0:coverage": "mocha tests/v12-9-0/features/**/*.test.js --reporter=json --outputFile=coverage-v12.9.0.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:check": "eslint . --format json > /tmp/eslint-report.json && echo 'Linting complete. Report saved to /tmp/eslint-report.json'",
    "lint:staged": "bash scripts/pre-commit.sh",
    "precommit": "bash scripts/pre-commit.sh",
    "quality": "npm run lint && npm run test:unit"
  },
  "keywords": [
    "electron",
    "browser",
    "osint",
    "automation",
    "websocket"
  ],
  "author": "Basset Hound Team",
  "license": "MIT",
  "dependencies": {
    "ajv-formats": "^3.0.1",
    "cheerio": "^1.1.0",
    "electron-updater": "^6.8.9",
    "node-fetch": "^3.3.2",
    "node-forge": "^1.3.3",
    "sharp": "^0.34.5",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "cross-env": "^7.0.3",
    "electron": "^39.2.7",
    "electron-builder": "^26.15.3",
    "eslint": "^8.56.0",
    "jest": "^30.4.2",
    "jest-environment-node": "^30.4.1",
    "jest-junit": "^17.0.0",
    "jsdom": "^26.1.0",
    "mocha": "^11.3.0",
    "speakeasy": "^2.0.0",
    "uuid": "^14.0.1"
  },
  "overrides": {
    "js-yaml": "^4.1.2"
  },
  "build": {
    "appId": "com.bassethound.browser",
    "productName": "Basset Hound Browser",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "src/main/main.js",
      "src/preload/preload.js",
      "renderer/**/*",
      "updater/**/*",
      "websocket/**/*",
      "evasion/**/*",
      "proxy/**/*",
      "tabs/**/*",
      "windows/**/*",
      "plugins/**/*",
      "cookies/**/*",
      "sessions/**/*",
      "profiles/**/*",
      "geolocation/**/*",
      "headers/**/*",
      "storage/**/*",
      "devtools/**/*",
      "history/**/*",
      "extraction/**/*",
      "inspector/**/*",
      "downloads/**/*",
      "blocking/**/*",
      "network/**/*",
      "network-analysis/**/*",
      "automation/**/*",
      "technology/**/*",
      "headless/**/*",
      "config/**/*",
      "recording/**/*",
      "input/**/*",
      "utils/**/*",
      "logging/**/*",
      "config.example.yaml",
      "!**/*.test.js",
      "!**/tests/**",
      "!**/*.md",
      "!**/examples/**"
    ],
    "extraResources": [
      {
        "from": "config.example.yaml",
        "to": "config.example.yaml"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "publisherName": "Basset Hound Team"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Basset Hound Browser"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Development",
      "maintainer": "Basset Hound Team",
      "vendor": "Basset Hound",
      "synopsis": "OSINT Browser with Bot Evasion",
      "description": "Custom Electron-based browser for OSINT investigations and AI-driven web automation with bot detection evasion"
    },
    "appImage": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "deb": {
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libuuid1"
      ]
    },
    "rpm": {
      "depends": [
        "gtk3",
        "libnotify",
        "nss",
        "libXScrnSaver",
        "libXtst",
        "xdg-utils",
        "at-spi2-core",
        "libuuid"
      ]
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    }
  }
}
