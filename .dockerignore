# Docker build context exclusions - reduces image size and improves build speed

# Version control and git
.git
.gitignore
.gitattributes
.gitmodules

# Dependencies (reinstalled during build via npm ci)
node_modules/
package-lock.json.backup

# Build outputs and artifacts
dist/
build/
release/
out/
*.egg-info/

# Development and IDE files
.vscode/
.idea/
.atom/
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.project
.settings/
*.sublime-project
*.sublime-workspace

# Testing infrastructure (not needed in production)
tests/
coverage/
.nyc_output/
*.test.js
jest.config.js
.mocha_output/

# Documentation (not needed in runtime image)
docs/
*.md
README*
CHANGELOG*
LICENSE
AUTHORS

# Client libraries (external tooling)
clients/

# Example/template configurations
*.example.*
.env.example
.editorconfig
.prettierrc
.prettierignore

# Temporary and cache files
tmp/
temp/
.cache/
.ccache/
.gradle/
.parcel-cache/
logs/
*.log
.npm/

# IDE metadata
.claude/

# Runtime data directories (user-specific, created at runtime)
recordings/data/
profiles/data/
cache/
sessions/data/

# Development-only scripts
scripts/install/

# CI/CD configuration (not needed in container)
.github/
.gitlab-ci.yml
.travis.yml
azure-pipelines.yml

# Local environment files
.env
.env.local
.env.*.local

# Archives and backups
*.tar.gz
*.zip
*.rar
*.7z
*.bak
*.backup

# Miscellaneous
Makefile
.npmrc
.yarnrc
.npmignore
