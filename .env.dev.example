# Basset Hound Browser - Development Environment Variables
# Copy this file to .env.dev and customize as needed

# ============================================================================
# Environment
# ============================================================================
NODE_ENV=development
LOG_LEVEL=debug

# ============================================================================
# Logging & Debugging
# ============================================================================
# Enable all debug output
DEBUG=basset-hound:*

# Enable Electron logging to console
ELECTRON_ENABLE_LOGGING=true

# Enable WebSocket server verbose output
VERBOSE_WS=true

# ============================================================================
# Display & UI
# ============================================================================
# Xvfb display number (for headless rendering)
DISPLAY=:99

# ============================================================================
# Features
# ============================================================================
# Enable hot reload for development
HOT_RELOAD=true

# Enable dev tools in Electron
ELECTRON_ENABLE_DEV_TOOLS=true

# Enable experimental features
EXPERIMENTAL=true

# ============================================================================
# Network
# ============================================================================
# WebSocket server port
WEBSOCKET_PORT=8765

# WebSocket server host
WEBSOCKET_HOST=0.0.0.0

# Enable request logging
LOG_REQUESTS=true

# ============================================================================
# Tor Configuration
# ============================================================================
# Use system Tor service
USE_SYSTEM_TOR=true

# Tor SOCKS port
TOR_SOCKS_PORT=9050

# Tor control port
TOR_CONTROL_PORT=9051

# ============================================================================
# Security (Dev - permissive)
# ============================================================================
# Rate limiting enabled (recommended even in dev)
RATE_LIMIT=true

# Rate limit requests per second
RATE_LIMIT_RPS=1000

# Allow self-signed certificates
ALLOW_SELF_SIGNED=true

# ============================================================================
# Performance
# ============================================================================
# Node.js max old space size (MB)
NODE_OPTIONS=--max-old-space-size=2048

# Maximum concurrent connections
MAX_CONNECTIONS=100

# Request timeout (ms)
REQUEST_TIMEOUT=30000

# ============================================================================
# Storage
# ============================================================================
# Data directory for profiles, cache, etc.
DATA_DIR=/app/data

# Downloads directory
DOWNLOADS_DIR=/app/downloads

# Screenshots directory
SCREENSHOTS_DIR=/app/screenshots

# ============================================================================
# Development Tools
# ============================================================================
# Enable profiling
ENABLE_PROFILING=true

# Enable memory snapshots
MEMORY_SNAPSHOTS=true
