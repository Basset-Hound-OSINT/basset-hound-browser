# ──────────────────────────────────────────────
# RAG Bootstrap – Environment Configuration
# Copy to .env and adjust values as needed.
# Or use config/config.yaml (recommended) which auto-generates .env via deploy.sh
# ──────────────────────────────────────────────

# Project identification
PROJECT_NAME=rag-bootstrap

# ──────────────────────────────────────────────────────────────────────────────
# INSTANCE ISOLATION — set a UNIQUE COMPOSE_PROJECT_NAME per instance.
# ──────────────────────────────────────────────────────────────────────────────
# Docker Compose reads COMPOSE_PROJECT_NAME from this .env automatically and uses
# it to prefix every container/network/volume: <COMPOSE_PROJECT_NAME>-<service>-N.
# The compose file NO LONGER hardcodes container_name (that was a GLOBAL name that
# collided the instant a second instance — or any stack reusing the old
# "rag-bootstrap-*" names — ran on the same host). Give each instance a distinct
# name here (e.g. COMPOSE_PROJECT_NAME=docs-rag-myproject) so multiple RAG stacks
# coexist with zero collisions. If unset, Compose falls back to the directory name
# (which can itself collide with another checkout of the same-named dir).
COMPOSE_PROJECT_NAME=rag-bootstrap

# ──────────────────────────────────────────────────────────────────────────────
# PORT SCHEME — single source of truth: RAG_PORT_BASE=10000
# ──────────────────────────────────────────────────────────────────────────────
# All published host ports derive from RAG_PORT_BASE. deploy.sh (generate_env)
# computes RAG_<svc>_PORT = RAG_PORT_BASE + offset and writes the concrete
# values into .env; compose files consume ${RAG_<svc>_PORT:-<default>} with
# defaults matching this table. Reserved band for this stack: 10000-10019
# (downstream apps take +20 and up). Container-side ports are unchanged;
# internal-only ports (postgres 5432, redis 6379, api 8000) are never
# published. Ollama 11434 stays an external well-known host port (not remapped).
#
#   Service            Env var                    Offset  Default host port
#   web (nginx)        RAG_PORT                   +0      10000
#   prometheus         RAG_PROMETHEUS_PORT        +10     10010
#   grafana            RAG_GRAFANA_PORT           +11     10011
#   loki               RAG_LOKI_PORT              +12     10012
#   alertmanager       RAG_ALERTMANAGER_PORT      +13     10013
#   postgres-exporter  RAG_PG_EXPORTER_PORT       +14     10014
#   redis-exporter     RAG_REDIS_EXPORTER_PORT    +15     10015
#   cadvisor           RAG_CADVISOR_PORT          +16     10016
RAG_PORT_BASE=10000

# Network settings — pick a FREE host port + an instance-unique network name.
RAG_PORT=10000
RAG_NETWORK_NAME=rag-bootstrap-net

# Derived service host ports (deploy.sh writes concrete values at runtime;
# uncomment to pin/override manually — defaults match the table above).
# RAG_PROMETHEUS_PORT=10010
# RAG_GRAFANA_PORT=10011
# RAG_LOKI_PORT=10012
# RAG_ALERTMANAGER_PORT=10013
# RAG_PG_EXPORTER_PORT=10014
# RAG_REDIS_EXPORTER_PORT=10015
# RAG_CADVISOR_PORT=10016

# PostgreSQL (used internally by Docker network)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ragdb
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpass

# Redis (used internally by Docker network)
REDIS_URL=redis://redis:6379/0

# ──────────────────────────────────────────────────────────────────────────────
# EMBEDDINGS — HARD PREREQUISITE: reachable host Ollama + model pulled.
# ──────────────────────────────────────────────────────────────────────────────
# This stack does NOT run an Ollama container and does NOT bundle
# sentence-transformers. Embeddings come from an EXTERNAL Ollama server at
# OLLAMA_BASE_URL. Before first deploy you MUST have:
#   1. Ollama running on the host (or reachable remote):  ollama serve
#   2. The embedding model pulled:                        ollama pull nomic-embed-text
# `./deploy.sh doctor` verifies both (endpoint reachable + model present).
# Canonical triple — change all three TOGETHER and reindex (stored vectors are
# dimension-locked): model=nomic-embed-text / dimension=768 / backend=ollama.
# Recommended: nomic-embed-text (v1.5) - purpose-built for RAG, 8192 token context
# Alternatives: mxbai-embed-large (1024), qwen3-embedding:8b (4096), all-minilm:l6-v2 (384)
# EMBEDDING_BACKEND=sentence-transformers is OPTIONAL and NOT installed by
# default; selecting it without the dependency raises an actionable error.
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768
EMBEDDING_BACKEND=ollama

# Document chunking. deploy.sh derives CHUNK_SIZE from config/config.yaml
# ingestion.chunk_size (canonical source, default 256) and writes it into .env;
# the value here only applies if you bypass deploy.sh.
CHUNK_SIZE=256
CHUNK_OVERLAP=50

# Ollama endpoint (serves BOTH embeddings and LLM generation — see the hard
# prerequisite above). host.docker.internal resolves to the host via the
# compose extra_hosts host-gateway entry; point at a remote Ollama by changing
# this URL (e.g. via an SSH forward to localhost:11434).
OLLAMA_BASE_URL=http://host.docker.internal:11434

# LLM model for generation/Q&A
# Default is small and pulled by the live smoke; larger models are optional — set LLM_MODEL and `ollama pull` accordingly.
LLM_MODEL=llama3.2:3b
LLM_TEMPERATURE=0.3
LLM_TIMEOUT=300

# RAG retrieval settings
RAG_TOP_K=5
RAG_MIN_SIMILARITY=0.7

# Document mounts
# DOCS_PATH: same-path read-only mount — the container sees your docs at the
# SAME absolute path as the host, so stored document filepaths are
# host-openable. DEFAULT-ON: docker-compose.yml falls back to ${PWD}/data/docs
# (run compose from the repo root, as deploy.sh does). Set this to your real
# docs root; leave commented to use the bundled ./data/docs default.
# DOCS_PATH=/absolute/path/to/your/documents
# RAG_INGEST_ROOT_GUARD: /api/ingest/directory refuses paths outside the
# DOCS_PATH docs root with 400. ON BY DEFAULT (guard root = DOCS_PATH, i.e.
# ${PWD}/data/docs unless overridden). Opt out with RAG_INGEST_ROOT_GUARD=off
# to allow arbitrary container-readable paths.
# RAG_INGEST_ROOT_GUARD=on
# WATCHER_ARCHIVE_MODE: what the auto-ingest watcher does with source files
# after ingest — off (default: never touch them) | copy (copy into archive/) |
# move (legacy relocate).
# WATCHER_ARCHIVE_MODE=off
# Legacy (optional - mount external docs folder):
# RAG_DOCS_VOLUME=/path/to/your/documents
